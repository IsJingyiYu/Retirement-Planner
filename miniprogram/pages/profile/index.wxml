<view class="page">
  <view class="title">你的日常设置</view>
  <view class="subtitle">提醒不是必须的，只有你想要的时候，它才会出现。</view>

  <view class="card profile-card">
    <view class="info-row">
      <view class="info-label">当前城市</view>
      <view class="info-value">{{cityText}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">兴趣标签</view>
      <view class="info-value">{{interestText}}</view>
    </view>
  </view>

  <view class="card reminder-card">
    <view class="reminder-title">明日提醒</view>
    <view class="reminder-desc">开启后，我们会在明天提醒你查看新的开始点。</view>
    <switch checked="{{reminderEnabled}}" bindchange="handleReminderChange" color="#3f7d4e" />
  </view>

  <button class="secondary-button" bindtap="goToSurvey">重新填写基础信息</button>
</view>
