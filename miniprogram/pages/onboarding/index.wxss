.onboarding-page {
  display: flex;
  align-items: center;
}

.hero {
  width: 100%;
  padding: 40rpx 32rpx;
  margin-top: 80rpx;
  background: linear-gradient(160deg, #fff8eb 0%, #f0e4cd 100%);
}

.eyebrow {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: #7f6b55;
}

.feature-list {
  margin: 32rpx 0;
}

.feature-item {
  margin-bottom: 16rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
  color: #4b3a2b;
}

.demo-button {
  margin-top: 18rpx;
}
