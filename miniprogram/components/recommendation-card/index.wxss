.recommendation-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.rec-head {
  display: flex;
  justify-content: space-between;
}

.rec-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #2f2419;
  padding-right: 16rpx;
}

.rec-distance {
  font-size: 24rpx;
  color: #6d5945;
}

.rec-type {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #3f7d4e;
}

.rec-desc {
  margin-top: 14rpx;
  font-size: 28rpx;
  color: #5d4d3f;
  line-height: 1.6;
}

.rec-reason {
  margin-top: 16rpx;
  display: inline-block;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #efe4cf;
  font-size: 24rpx;
  color: #5d4d3f;
}
