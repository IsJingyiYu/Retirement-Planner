.welcome {
  margin-bottom: 24rpx;
}

.entry-row {
  display: flex;
  margin: 24rpx 0 32rpx;
}

.entry-button {
  flex: 1;
  margin-right: 16rpx;
}

.entry-button:last-child {
  margin-right: 0;
}

.section {
  margin-top: 8rpx;
}

.menu-grid {
  margin-bottom: 28rpx;
}

.menu-card {
  width: 100%;
  margin-bottom: 18rpx;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: #fffaf1;
  border: 2rpx solid #e5d4bb;
  text-align: left;
  line-height: 1.4;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2f2419;
}

.menu-desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #6d5945;
}
