page {
  background: linear-gradient(180deg, #f8f1e6 0%, #f4eee3 100%);
  color: #2f2419;
  font-family: "PingFang SC", "Hiragino Sans GB", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.card {
  background: #fffaf1;
  border: 2rpx solid #e5d4bb;
  border-radius: 28rpx;
  box-shadow: 0 14rpx 32rpx rgba(95, 74, 44, 0.08);
}

.title {
  font-size: 44rpx;
  font-weight: 600;
  line-height: 1.3;
}

.subtitle {
  margin-top: 12rpx;
  color: #6d5945;
  font-size: 28rpx;
  line-height: 1.6;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.primary-button {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: #3f7d4e;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.secondary-button {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: transparent;
  color: #3f7d4e;
  border: 2rpx solid #3f7d4e;
  font-size: 30rpx;
  font-weight: 600;
}

.ghost-button {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: #d9ead2;
  color: #3f7d4e;
  font-size: 28rpx;
}

.tag {
  display: inline-block;
  padding: 10rpx 18rpx;
  margin: 0 12rpx 12rpx 0;
  border-radius: 999rpx;
  background: #efe4cf;
  color: var(--text);
  font-size: 24rpx;
}
